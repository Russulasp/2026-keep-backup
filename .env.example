# Host-side (WSL) absolute path to an existing logged-in Chromium profile directory.
# This directory is an external asset and must stay outside this repository.
# Used for local runs directly, and for Docker bind mount source.
KEEP_BROWSER_PROFILE_DIR_HOST=

# Container-side profile mount path.
# Usually leave default as /keep-profile.
KEEP_BROWSER_PROFILE_DIR_CONTAINER=/keep-profile
